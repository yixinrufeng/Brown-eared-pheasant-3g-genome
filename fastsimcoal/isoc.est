// Priors and rules file
// *********************

[PARAMETERS]
//#isInt? #name   #dist.#min  #max
//all Ns are in number of haploid individuals
1  NMR	logunif	100	100000	output
1  NMB	logunif	100	100000	output
1  NANB  logunif 100     100000  output
0  TPROP	logunif	0.0001	0.5	output
1	TSP	unif 10	20000	output

[RULES]
NANB > NMB

[COMPLEX PARAMETERS]
1	NANC =	NMR+NANB	output
0	RATIO	=	NANB/NMB	hide
0	RTEA	=	log(RATIO)	hide
0	R1	=	RTEA/TSP	hide
